{
  "name": "@workspace/companion",
  "version": "0.0.1",
  "description": "F1SimHub Companion — desktop app that listens to F1 25 UDP telemetry and auto-uploads sessions",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "package": "electron-builder --config electron-builder.json5 --publish never"
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "f1-telemetry-client": "^0.1.26"
  },
  "devDependencies": {
    "@rollup/rollup-darwin-arm64": "4.60.3",
    "@rollup/rollup-darwin-x64": "4.60.3",
    "@rollup/rollup-linux-x64-gnu": "4.60.3",
    "@rollup/rollup-win32-x64-msvc": "4.60.3",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "electron": "^34.5.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "^5.8.3",
    "vite": "catalog:"
  }
}
